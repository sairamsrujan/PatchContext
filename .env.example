# PatchContext environment variables. Copy to .env and fill in what you have.
# .env is gitignored; in deployment these come from the platform's secret store.
# Every value here has a sensible default in src/patchcontext/config.py —
# only the tokens/keys are actually required, and only from the phase that uses them.

# --- GitHub ingestion (required from Phase 1) ---
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=fastapi/fastapi
INGEST_WINDOW_YEARS=3
MIN_ISSUE_COMMENTS=2

# --- Primary LLM endpoint, OpenAI-compatible (required from Phase 4) ---
# Defaults target NVIDIA; to use any other provider, override all three.
# NVIDIA_API_KEY is accepted as an alias for LLM_API_KEY.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi_your_key_here
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b

# --- Fallback LLM endpoint (optional; used on 429/5xx failover) ---
# OPENROUTER_API_KEY is accepted as an alias for LLM_FALLBACK_API_KEY.
LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_API_KEY=sk-or_your_key_here
LLM_FALLBACK_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# --- Local model execution (low-RAM defaults; also matches HF Spaces CPU tier) ---
# MODEL_DEVICE=mps is the fast opt-in on Apple Silicon, but large embedding
# runs on MPS can balloon unified memory. cpu + batch 8 peaks around 4-5 GB.
MODEL_DEVICE=cpu
EMBED_BATCH_SIZE=8
EMBED_MAX_SEQ_TOKENS=1024

# --- RAGAs judge LLM (required for Phase 6; default: Google AI Studio free tier) ---
RAGAS_JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
RAGAS_JUDGE_API_KEY=your_google_ai_studio_key_here
RAGAS_JUDGE_MODEL=gemini-2.0-flash
