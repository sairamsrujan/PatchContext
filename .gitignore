# Secrets — never commit; use .env.example as the template
.env

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
dist/
.pytest_cache/

# Raw GitHub cache is reproducible from scripts/run_ingestion.py — never committed
data/raw/*
!data/raw/.gitkeep

# The serving index artifacts (embeddings.npy + metadata.parquet + stats.json)
# ARE committed so the app runs out of the box.

# OS / editors
.DS_Store

# Local model caches
.cache/

# unused in serving (retriever uses embeddings.npy); regenerated by build_index
data/index/faiss.index

# resumable eval checkpoint (regenerated by run_ragas)
src/patchcontext/eval/results/answers.partial.jsonl

# owner-specific Cloud Run redeploy helpers (reference a private image; kept local)
Dockerfile.overlay
cloudbuild.overlay.yaml
